  "shortcuts": [
    {
      "name": "Search",
      "short_name": "Search",
      "description": "Search for music",
      "url": "/search?source=shortcut",
      "icons": [
        {
          "src": "favicons/android/android-launchericon-96-96.png",
          "sizes": "96x96"
        },
        {
          "src": "favicons/android/android-launchericon-192-192.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "Favorites",
      "short_name": "Favorites",
      "description": "Your favorite tracks",
      "url": "/favorites?source=shortcut",
      "icons": [
        {
          "src": "favicons/android/android-launchericon-96-96.png",
          "sizes": "96x96"
        },
        {
          "src": "favicons/android/android-launchericon-192-192.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "Playlists",
      "short_name": "Playlists",
      "description": "Your playlists",
      "url": "/playlists?source=shortcut",
      "icons": [
        {
          "src": "favicons/android/android-launchericon-96-96.png",
          "sizes": "96x96"
        },
        {
          "src": "favicons/android/android-launchericon-192-192.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "Trending",
      "short_name": "Trending",
      "description": "Trending music",
      "url": "/trending?source=shortcut",
      "icons": [
        {
          "src": "favicons/android/android-launchericon-96-96.png",
          "sizes": "96x96"
        },
        {
          "src": "favicons/android/android-launchericon-192-192.png",
          "sizes": "192x192"
        }
      ]
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+elysium",
      "url": "/?share=%s"
    }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "file_handlers": [
    {
      "action": "/import",
      "accept": {
        "application/json": [
          ".json"
        ]
      }
    }
  ],
  "prefer_related_applications": false,
  "edge_side_panel": {
    "preferred_width": 400
  }
}