{
  "id": "/",
  "short_name": "Elysium",
  "name": "Elysium \u2013 Private Music Player",
  "description": "Privacy-focused music player powered by the Invidious API. Listen without ads or tracking.",
  "display": "standalone",
  "display_override": [
    "window-controls-overlay",
    "standalone",
    "minimal-ui",
    "browser"
  ],
  "scope": "/",
  "start_url": "/?source=pwa",
  "theme_color": "#1a1b1e",
  "background_color": "#1a1b1e",
  "orientation": "any",
  "dir": "ltr",
  "lang": "en",
  "categories": [
