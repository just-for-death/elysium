# Elysium – environment template
# Copy this file to .env and fill in real values.
# In Docker, pass these via docker-compose environment: instead.
# Leave REACT_APP_API_URL empty for self-hosted (uses same origin for /api/countryCode)
REACT_APP_API_URL=

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000

# Directory where library.json is stored. Defaults to the server/ folder.
# Set to a Docker volume path (e.g. /data) to persist data across container restarts.
DATA_DIR=

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or "*" for all.
# Restrict this to your actual client origins in production.
# Example: ALLOWED_ORIGINS=https://elysium.example.com,app://localhost
ALLOWED_ORIGINS=*

# ── Sync server ────────────────────────────────────────────────────────────────
# URL of the companion sync/websocket server (multi-device real-time sync).
SYNC_SERVER_URL=http://localhost:3001

# ── Invidious ──────────────────────────────────────────────────────────────────
# Set to true to allow the Invidious proxy to reach local/private network addresses.
# Leave false (default) in production to prevent SSRF attacks.
ALLOW_LOCAL_NETWORK=false

# ── Web Push (optional – push notifications) ───────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:you@example.com

# Protect the /push/broadcast endpoint with a secret token
# Set to any long random string, then include as Authorization: Bearer <secret>
BROADCAST_SECRET=

# ── Gotify (optional – push notifications via Gotify) ──────────────────────────
# Only required if you use the Gotify relay endpoint.
GOTIFY_SERVER_URL=

# ── TLS / Proxy ────────────────────────────────────────────────────────────────
# Set to true only when serving behind an HTTPS reverse proxy
ENABLE_HSTS=false
